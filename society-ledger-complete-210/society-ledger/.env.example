# Society Ledger — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit the actual .env file to version control

# ─── Security ───────────────────────────────────────────
# Must be at least 256 bits (32+ chars). Generate with:
# openssl rand -base64 64
JWT_SECRET=society-ledger-jwt-secret-min-256-bits-CHANGE-THIS-IN-PRODUCTION

# ─── Database ───────────────────────────────────────────
SPRING_DATASOURCE_URL= jdbc:postgresql://ep-odd-hat-atl59pyz-pooler.c-9.us-east-1.aws.neon.tech/society_ledger?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=npg_d4Z1MlrEazfX

# ─── Mail (OTP emails) ──────────────────────────────────
