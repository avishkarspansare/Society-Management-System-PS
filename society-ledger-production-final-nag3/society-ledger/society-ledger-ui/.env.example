# Society Ledger — Frontend Environment
# Copy this to .env.local for local development

# API Gateway URL (for production builds with no Vite proxy)
# VITE_API_BASE_URL=https://api.societyledger.com/api/v1

# When using docker compose locally, leave empty (Vite proxy handles /api → gateway:8080)
# VITE_API_BASE_URL=
