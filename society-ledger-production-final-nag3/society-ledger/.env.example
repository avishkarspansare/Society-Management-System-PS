# ============================================================
# Society Ledger — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Security ───────────────────────────────────────────────
# Must be at least 256 bits (32+ chars). Generate with:
#   openssl rand -base64 64
JWT_SECRET=society-ledger-jwt-secret-min-256-bits-CHANGE-THIS-IN-PRODUCTION

# ─── Database (Local Docker) ─────────────────────────────────
DB_PASSWORD=sl_pass_2024

# ─── Database (Neon Production) ──────────────────────────────
# SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# DB_USERNAME=neondb_owner
# DB_PASSWORD=your-neon-password

# ─── Mail (OTP / Notifications) ──────────────────────────────
# For Gmail: enable App Passwords → myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yoursociety.com
MAIL_PASSWORD=your-app-password-here
MAIL_ENABLED=true

# ─── File Storage ────────────────────────────────────────────
EXPENSE_STORAGE_DIR=/app/data/expense-proofs
RECEIPT_STORAGE_DIR=/app/data/receipts
AUDIT_STORAGE_DIR=/app/data/audit-reports

# ─── Kafka ───────────────────────────────────────────────────
# SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092   # (Docker)
# SPRING_KAFKA_BOOTSTRAP_SERVERS=broker1:9092 # (External)

# ─── Spring Profiles ─────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=prod   # Use for Neon + production settings
# SPRING_PROFILES_ACTIVE=default # Use for local Docker PostgreSQL

# ─── Service URLs (Docker internal — set in docker-compose) ──
# AUTH_SERVICE_URL=http://auth-service:8081
# SOCIETY_SERVICE_URL=http://society-service:8082
# FINANCE_SERVICE_URL=http://finance-service:8083
# STATEMENT_SERVICE_URL=http://statement-service:8084
# RECEIPT_SERVICE_URL=http://receipt-service:8085
# AUDIT_SERVICE_URL=http://audit-service:8086
# QUERY_SERVICE_URL=http://query-service:8087
# NOTIFICATION_SERVICE_URL=http://notification-service:8088
